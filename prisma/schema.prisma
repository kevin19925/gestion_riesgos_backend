generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique @db.VarChar(255)
  nombre      String    @db.VarChar(255)
  descripcion String?
  permisos    Json?
  activo      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  ambito      String    @default("OPERATIVO") @db.VarChar(20)
  usuarios    Usuario[]
}

model Usuario {
  id                            Int                  @id @default(autoincrement())
  nombre                        String
  email                         String               @unique
  password                      String
  cargoId                       Int?
  activo                        Boolean              @default(true)
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
  roleId                        Int
  fotoPerfil                    String?
  alertasVencimiento            AlertaVencimiento[]
  areasDirector                 Area[]               @relation("DirectorArea")
  incidenciasResponsable        Incidencia[]
  observaciones                 Observacion[]        @relation("AutorObservacion")
  procesosResponsable           Proceso[]            @relation("ResponsableProceso")
  procesosResponsablesMultiples ProcesoResponsable[] @relation("ProcesoResponsables")
  cargo                         Cargo?               @relation(fields: [cargoId], references: [id])
  roleRelacion                  Role                 @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  procesosParticipantes         Proceso[]            @relation("Participantes")
  asistenciasProceso            AsistentesProceso[]  @relation("AsistentesProceso")
  asistenciasReunion            AsistenciaReunion[]  @relation("AsistenciaReunion")
}

model Cargo {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  usuarios    Usuario[]
}

model Gerencia {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  subdivision String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  procesos    Proceso[]
}

model Area {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  directorId  Int?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  director    Usuario?  @relation("DirectorArea", fields: [directorId], references: [id])
  procesos    Proceso[]
}

model Proceso {
  id                             Int                  @id @default(autoincrement())
  nombre                         String               @unique
  descripcion                    String?
  objetivo                       String?
  tipo                           String?
  responsableId                  Int?
  areaId                         Int?
  vicepresidencia                String?
  estado                         String               @default("borrador")
  activo                         Boolean              @default(true)
  analisis                       String?
  documentoUrl                   String?
  documentoNombre                String?
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  sigla                          String?
  documentoCaracterizacionNombre String?
  documentoCaracterizacionUrl    String?
  documentoFlujoGramaNombre      String?
  documentoFlujoGramaUrl         String?
  gerenciaId                     Int?
  contextos                      Contexto[]
  contextoItems                  ContextoItem[]
  dofaItems                      DofaItem[]
  incidencias                    Incidencia[]
  normatividades                 Normatividad[]
  observaciones                  Observacion[]
  area                           Area?                @relation(fields: [areaId], references: [id])
  gerencia                       Gerencia?            @relation(fields: [gerenciaId], references: [id])
  responsable                    Usuario?             @relation("ResponsableProceso", fields: [responsableId], references: [id])
  responsables                   ProcesoResponsable[]
  riesgos                        Riesgo[]
  participantes                  Usuario[]            @relation("Participantes")
  asistentes                     AsistentesProceso[]
  reuniones                      ReunionProceso[]

  @@index([gerenciaId])
}

model ProcesoResponsable {
  id        Int      @id @default(autoincrement())
  procesoId Int
  usuarioId Int
  createdAt DateTime @default(now())
  modo      String   @db.VarChar(20)
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation("ProcesoResponsables", fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([procesoId, usuarioId, modo])
  @@index([procesoId])
  @@index([usuarioId])
  @@index([modo])
}

model DofaItem {
  id          Int      @id @default(autoincrement())
  procesoId   Int
  tipo        String
  descripcion String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proceso     Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)

  @@index([procesoId])
}

model Normatividad {
  id                    Int      @id @default(autoincrement())
  procesoId             Int
  numero                Int
  nombre                String
  estado                String
  regulador             String?
  sanciones             String?
  plazoImplementacion   String?
  cumplimiento          String?
  detalleIncumplimiento String?
  riesgoIdentificado    String?
  clasificacion         String?
  comentarios           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  proceso               Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)

  @@index([procesoId])
}

model Contexto {
  id          Int      @id @default(autoincrement())
  procesoId   Int
  tipo        String
  descripcion String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proceso     Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)

  @@index([procesoId])
}

model ContextoItem {
  id            Int      @id @default(autoincrement())
  procesoId     Int
  tipo          String   @db.VarChar(255)
  signo         String   @db.VarChar(20)
  descripcion   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  enviarADofa   Boolean? @default(false)
  dofaDimension String?  @db.VarChar(50)
  proceso       Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)

  @@index([procesoId])
}

model Riesgo {
  id                          Int                       @id @default(autoincrement())
  procesoId                   Int
  numero                      Int
  descripcion                 String
  clasificacion               String?
  numeroIdentificacion        String?
  tipologiaTipo1Id            Int?
  tipologiaTipo2Id            Int?
  objetivoId                  Int?
  origen                      String?
  vicepresidenciaGerenciaAlta String?
  gerencia                    String?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  tipologiaTipo3Id            Int?
  tipologiaTipo4Id            Int?
  causas                      CausaRiesgo[]
  controles                   Control[]
  evaluacion                  EvaluacionRiesgo?
  incidencias                 Incidencia[]
  planesAccion                PlanAccion[]
  priorizacion                PriorizacionRiesgo?
  objetivo                    Objetivo?                 @relation(fields: [objetivoId], references: [id])
  proceso                     Proceso                   @relation(fields: [procesoId], references: [id])
  tipologiaTipo2Relacion      SubtipoRiesgo?            @relation(fields: [tipologiaTipo2Id], references: [id], map: "Riesgo_subtipoRiesgoId_fkey")
  tipologiaTipo1Relacion      TipoRiesgo?               @relation(fields: [tipologiaTipo1Id], references: [id], map: "Riesgo_tipoRiesgoId_fkey")
  tipologiaTipo3Relacion      TipologiaRiesgoExtendida? @relation("Tipologia3", fields: [tipologiaTipo3Id], references: [id])
  tipologiaTipo4Relacion      TipologiaRiesgoExtendida? @relation("Tipologia4", fields: [tipologiaTipo4Id], references: [id])

  @@unique([procesoId, numero])
  @@index([procesoId])
  @@index([createdAt])
}

model CausaRiesgo {
  id                 Int                   @id @default(autoincrement())
  riesgoId           Int
  descripcion        String
  fuenteCausa        String?
  frecuencia         String?
  seleccionada       Boolean               @default(false)
  alertas            AlertaVencimiento[]
  riesgo             Riesgo                @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
  controlesDerivados Control?              @relation("CausaToControl")
  controles          ControlRiesgo[]
  historialEstados   HistorialEstadoPlan[]
  incidencias        Incidencia[]
  planesAccion       PlanAccion[]

  @@index([riesgoId])
}

model ControlRiesgo {
  id                                  Int          @id @default(autoincrement())
  causaRiesgoId                       Int
  descripcion                         String
  tipoControl                         String?
  responsable                         String?
  aplicabilidad                       Int?
  cobertura                           Int?
  facilidadUso                        Int?
  segregacion                         Int?
  naturaleza                          Int?
  desviaciones                        Int?
  puntajeControl                      Int?
  evaluacionPreliminar                String?
  evaluacionDefinitiva                String?
  estandarizacionPorcentajeMitigacion Int?
  disminuyeFrecuenciaImpactoAmbas     String?
  descripcionControl                  String?
  recomendacion                       String?
  tipoMitigacion                      String?
  estadoAmbos                         String?
  recalculadoEn                       DateTime?
  planAccionVinculadoId               Int?
  causaRiesgo                         CausaRiesgo  @relation(fields: [causaRiesgoId], references: [id], onDelete: Cascade)
  planAccionVinculado                 PlanAccion?  @relation("ControlVinculadoPlan", fields: [planAccionVinculadoId], references: [id])

  @@index([planAccionVinculadoId])
}

model EvaluacionRiesgo {
  id                   Int      @id @default(autoincrement())
  riesgoId             Int      @unique
  impactoPersonas      Int
  impactoLegal         Int
  impactoAmbiental     Int
  impactoProcesos      Int
  impactoReputacion    Int
  impactoEconomico     Int
  impactoTecnologico   Int
  probabilidad         Int
  impactoGlobal        Int
  impactoMaximo        Int
  riesgoInherente      Int
  nivelRiesgo          String
  probabilidadResidual Int?
  impactoResidual      Int?
  riesgoResidual       Int?
  nivelRiesgoResidual  String?
  evaluadoPor          String?
  fechaEvaluacion      DateTime @default(now())
  confidencialidadSGSI Int?
  disponibilidadSGSI   Int?
  integridadSGSI       Int?
  riesgo               Riesgo   @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model PriorizacionRiesgo {
  id                  Int          @id @default(autoincrement())
  riesgoId            Int          @unique
  calificacionFinal   Int?
  respuesta           String?
  responsable         String?
  puntajePriorizacion Int?
  fechaAsignacion     DateTime     @default(now())
  planesAccion        PlanAccion[]
  riesgo              Riesgo       @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model PlanAccion {
  id                      Int                 @id @default(autoincrement())
  priorizacionId          Int?
  riesgoId                Int?
  incidenciaId            Int?
  nombre                  String?
  objetivo                String?
  descripcion             String
  responsable             String?
  fechaInicio             DateTime?
  fechaFin                DateTime?
  fechaProgramada         DateTime?
  fechaEjecucion          DateTime?
  estado                  String
  prioridad               Int?
  presupuesto             Float?
  porcentajeAvance        Int?
  observaciones           String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  causaRiesgoId           Int?
  tipoGestion             String?
  origenMigracion         Boolean?            @default(false)
  causaRiesgo             CausaRiesgo?        @relation(fields: [causaRiesgoId], references: [id])
  incidencia              Incidencia?         @relation(fields: [incidenciaId], references: [id])
  priorizacion            PriorizacionRiesgo? @relation(fields: [priorizacionId], references: [id], onDelete: Cascade)
  riesgo                  Riesgo?             @relation(fields: [riesgoId], references: [id])
  controlesVinculados     ControlRiesgo[]     @relation("ControlVinculadoPlan")

  @@index([causaRiesgoId])
}

model Control {
  id                     Int          @id @default(autoincrement())
  riesgoId               Int
  descripcion            String?
  tipoControl            String?
  diseño                Int
  ejecucion              Int
  solidez                Int
  efectividad            Float
  riesgoResidual         Float
  clasificacionResidual  String
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  causaRiesgoOrigenId    Int?         @unique
  fechaCreacionDesdePlan DateTime?
  causaRiesgoOrigen      CausaRiesgo? @relation("CausaToControl", fields: [causaRiesgoOrigenId], references: [id])
  riesgo                 Riesgo       @relation(fields: [riesgoId], references: [id], onDelete: Cascade)

  @@index([riesgoId])
  @@index([causaRiesgoOrigenId])
}

model Incidencia {
  id                      Int          @id @default(autoincrement())
  codigo                  String?      @unique
  riesgoId                Int?
  procesoId               Int?
  titulo                  String?
  descripcion             String
  estado                  String
  fechaOcurrencia         DateTime
  fechaReporte            DateTime?
  fechaResolucion         DateTime?
  reportadoPor            String?
  responsableId           Int?
  accionesCorrectivas     String?
  impactosMaterializacion Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  causaRiesgoId           Int?
  causaRiesgo             CausaRiesgo? @relation(fields: [causaRiesgoId], references: [id])
  proceso                 Proceso?     @relation(fields: [procesoId], references: [id])
  responsable             Usuario?     @relation(fields: [responsableId], references: [id])
  riesgo                  Riesgo?      @relation(fields: [riesgoId], references: [id])
  planesAccion            PlanAccion[]

  @@index([procesoId])
  @@index([riesgoId])
  @@index([causaRiesgoId])
  @@index([fechaOcurrencia])
}

model TipoRiesgo {
  id          Int             @id @default(autoincrement())
  nombre      String          @unique
  descripcion String?
  riesgos     Riesgo[]
  subtipos    SubtipoRiesgo[]
}

model SubtipoRiesgo {
  id                   Int                        @id @default(autoincrement())
  nombre               String
  descripcion          String?
  tipoRiesgoId         Int
  riesgos              Riesgo[]
  tipoRiesgo           TipoRiesgo                 @relation(fields: [tipoRiesgoId], references: [id], onDelete: Cascade)
  tipologiasExtendidas TipologiaRiesgoExtendida[]

  @@unique([nombre, tipoRiesgoId], name: "nombre_tipo")
}

model TipologiaRiesgoExtendida {
  id          Int            @id @default(autoincrement())
  subtipoId   Int?
  nivel       Int
  nombre      String
  descripcion String?
  activo      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
  riesgos3    Riesgo[]       @relation("Tipologia3")
  riesgos4    Riesgo[]       @relation("Tipologia4")
  subtipo     SubtipoRiesgo? @relation(fields: [subtipoId], references: [id], onDelete: Cascade)

  @@unique([nivel, nombre])
  @@index([subtipoId])
}

model Objetivo {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  descripcion String   @unique
  riesgos     Riesgo[]
}

model FrecuenciaCatalog {
  id          Int    @id @default(autoincrement())
  label       String @unique
  descripcion String
  peso        Int?   @default(3)
}

model FuenteCatalog {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

model OrigenCatalog {
  id     Int     @id @default(autoincrement())
  codigo String? @unique
  nombre String  @unique
}

model ConsecuenciaCatalog {
  id     Int     @id @default(autoincrement())
  codigo String? @unique
  nombre String  @unique
}

model ImpactoTipo {
  id      Int            @id @default(autoincrement())
  clave   String         @unique
  nombre  String         @unique
  niveles ImpactoNivel[]
}

model ImpactoNivel {
  id            Int         @id @default(autoincrement())
  impactoTipoId Int
  nivel         Int
  descripcion   String
  impactoTipo   ImpactoTipo @relation(fields: [impactoTipoId], references: [id], onDelete: Cascade)

  @@unique([impactoTipoId, nivel])
}

model MapaConfig {
  id                          Int                          @id @default(autoincrement())
  nombre                      String
  ejes                        String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  calificacionInherenteConfig CalificacionInherenteConfig?
}

model Configuracion {
  id          Int     @id @default(autoincrement())
  clave       String  @unique
  valor       String
  tipo        String
  descripcion String?
}

model CalificacionInherenteConfig {
  id              Int                           @id @default(autoincrement())
  nombre          String                        @unique @default("Configuración Principal")
  activa          Boolean                       @default(true)
  descripcion     String?
  mapaConfigId    Int?                          @unique
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  mapaConfig      MapaConfig?                   @relation(fields: [mapaConfigId], references: [id])
  excepciones     ExcepcionCalificacion[]
  formulaBase     FormulaCalificacionInherente?
  rangos          RangoCalificacion[]
  reglaAgregacion ReglaAgregacionCalificacion?
}

model FormulaCalificacionInherente {
  id            Int                         @id @default(autoincrement())
  configId      Int                         @unique
  tipoOperacion String                      @default("multiplicacion")
  campos        Json
  orden         Int                         @default(1)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  config        CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model ExcepcionCalificacion {
  id          Int                         @id @default(autoincrement())
  configId    Int
  condiciones Json
  resultado   Float
  prioridad   Int                         @default(1)
  activa      Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  config      CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model RangoCalificacion {
  id            Int                         @id @default(autoincrement())
  configId      Int
  nivelNombre   String
  valorMinimo   Float
  valorMaximo   Float
  incluirMinimo Boolean                     @default(true)
  incluirMaximo Boolean                     @default(true)
  orden         Int
  activo        Boolean                     @default(true)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  config        CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([configId, orden])
}

model ReglaAgregacionCalificacion {
  id             Int                         @id @default(autoincrement())
  configId       Int                         @unique
  tipoAgregacion String                      @default("maximo")
  tablaOrigen    String
  campoOrigen    String
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  config         CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model Observacion {
  id        Int      @id @default(autoincrement())
  procesoId Int
  autorId   Int
  texto     String
  tipo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  autor     Usuario  @relation("AutorObservacion", fields: [autorId], references: [id])
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)

  @@index([procesoId])
  @@index([autorId])
}

model ConfiguracionResidual {
  id                                  Int                        @id @default(autoincrement())
  nombre                              String                     @unique
  descripcion                         String?
  activa                              Boolean                    @default(true)
  createdAt                           DateTime                   @default(now())
  updatedAt                           DateTime                   @default(now()) @updatedAt
  porcentajeReduccionDimensionCruzada Float?
  opcionesCriterios                   OpcionCriterioResidual[]
  pesosCriterios                      PesoCriterioResidual[]
  rangosEvaluacion                    RangoEvaluacionResidual[]
  rangosNivelRiesgo                   RangoNivelRiesgoResidual[]
  tablaMitigacion                     TablaMitigacionResidual[]
}

model PesoCriterioResidual {
  id        Int                   @id @default(autoincrement())
  configId  Int
  criterio  String
  peso      Float
  orden     Int
  activo    Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now())
  config    ConfiguracionResidual @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model RangoEvaluacionResidual {
  id            Int                   @id @default(autoincrement())
  configId      Int
  nivelNombre   String
  valorMinimo   Float
  valorMaximo   Float
  incluirMinimo Boolean               @default(true)
  incluirMaximo Boolean               @default(true)
  orden         Int
  activo        Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now())
  config        ConfiguracionResidual @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model TablaMitigacionResidual {
  id         Int                   @id @default(autoincrement())
  configId   Int
  evaluacion String
  porcentaje Float
  orden      Int
  activo     Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @default(now())
  config     ConfiguracionResidual @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model OpcionCriterioResidual {
  id        Int                   @id @default(autoincrement())
  configId  Int
  criterio  String
  label     String
  valor     Float
  orden     Int
  activo    Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now())
  config    ConfiguracionResidual @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model RangoNivelRiesgoResidual {
  id            Int                   @id @default(autoincrement())
  configId      Int
  nivelNombre   String
  valorMinimo   Float
  valorMaximo   Float
  incluirMinimo Boolean               @default(true)
  incluirMaximo Boolean               @default(true)
  orden         Int
  activo        Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now())
  config        ConfiguracionResidual @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model CalificacionResidualConfig {
  id                        Int                         @id @default(autoincrement())
  nombre                    String                      @unique @default("Configuración Residual Principal")
  activa                    Boolean                     @default(true)
  descripcion               String?
  decimalesEfectividad      Int                         @default(2)
  decimalesResidual         Int                         @default(2)
  maxPuntosEfectividad      Int                         @default(15)
  formulaTipo               String                      @default("reduccion_por_efectividad")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @default(now())
  RangoCalificacionResidual RangoCalificacionResidual[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model HistorialEvento {
  id                Int      @id @default(autoincrement())
  fecha             DateTime @default(now())
  usuarioId         Int?
  usuarioEmail      String?  @db.VarChar(255)
  usuarioNombre     String?  @db.VarChar(255)
  procesoId         Int?
  procesoNombre     String?  @db.VarChar(255)
  modulo            String   @db.VarChar(100)
  pagina            String   @db.VarChar(150)
  seccion           String?  @db.VarChar(150)
  entidadTipo       String   @db.VarChar(100)
  entidadId         Int?
  accion            String   @db.VarChar(50)
  descripcion       String?
  valoresAnteriores Json?
  valoresNuevos     Json?
  valorAnterior     String?  @db.VarChar(500)
  valorNuevo        String?  @db.VarChar(500)

  @@index([fecha])
  @@index([modulo])
  @@index([procesoId])
}

model RangoCalificacionResidual {
  id                         Int                        @id @default(autoincrement())
  configId                   Int
  nivelNombre                String
  valorMinimo                Float
  valorMaximo                Float
  incluirMinimo              Boolean                    @default(true)
  incluirMaximo              Boolean                    @default(true)
  orden                      Int
  activo                     Boolean                    @default(true)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @default(now())
  CalificacionResidualConfig CalificacionResidualConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([configId, orden])
}

model AuditLog {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  usuarioNombre   String
  usuarioEmail    String
  usuarioRole     String
  accion          String   @db.VarChar(20)
  tabla           String   @db.VarChar(100)
  registroId      Int?
  registroDesc    String?
  cambios         Json?
  datosAnteriores Json?
  datosNuevos     Json?
  ipAddress       String?  @db.VarChar(50)
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([usuarioId])
  @@index([tabla])
  @@index([accion])
  @@index([createdAt])
  @@index([tabla, accion])
  @@index([createdAt, tabla])
  @@index([usuarioId, createdAt])
}

model AlertaVencimiento {
  id              Int         @id @default(autoincrement())
  causaRiesgoId   Int
  usuarioId       Int
  tipo            String      @db.VarChar(20)
  diasRestantes   Int?
  leida           Boolean     @default(false)
  fechaGeneracion DateTime    @default(now())
  fechaLectura    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt
  causaRiesgo     CausaRiesgo @relation(fields: [causaRiesgoId], references: [id], onDelete: Cascade)
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([causaRiesgoId])
  @@index([usuarioId])
  @@index([leida])
  @@index([fechaGeneracion])
  @@index([tipo])
}

model HistorialEstadoPlan {
  id               Int         @id @default(autoincrement())
  causaRiesgoId    Int
  estado           String
  responsable      String?
  detalle          String?
  decision         String?
  porcentajeAvance Int?
  fechaEstado      DateTime?
  registradoEn     DateTime    @default(now())
  origenMigracion  Boolean     @default(true)
  causaRiesgo      CausaRiesgo @relation(fields: [causaRiesgoId], references: [id], onDelete: Cascade)

  @@index([causaRiesgoId])
  @@index([estado])
}

model AsistentesProceso {
  id        Int      @id @default(autoincrement())
  procesoId Int
  usuarioId Int
  rol       String   @db.VarChar(50)
  createdAt DateTime @default(now())
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation("AsistentesProceso", fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([procesoId, usuarioId])
  @@index([procesoId])
  @@index([usuarioId])
}

model ReunionProceso {
  id          Int                  @id @default(autoincrement())
  procesoId   Int
  fecha       DateTime
  descripcion String
  estado      String               @default("programada") @db.VarChar(20)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt
  proceso     Proceso              @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  asistencias AsistenciaReunion[]

  @@index([procesoId])
  @@index([fecha])
  @@index([estado])
}

model AsistenciaReunion {
  id            Int            @id @default(autoincrement())
  reunionId     Int
  usuarioId     Int
  asistio       Boolean        @default(false)
  observaciones String?
  registradoEn  DateTime?
  reunion       ReunionProceso @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  usuario       Usuario        @relation("AsistenciaReunion", fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([reunionId, usuarioId])
  @@index([reunionId])
  @@index([usuarioId])
}

