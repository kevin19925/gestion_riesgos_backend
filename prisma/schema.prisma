generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique @db.VarChar(255)
  nombre      String    @db.VarChar(255)
  descripcion String?
  permisos    Json?
  activo      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  usuarios    Usuario[]
}

model Usuario {
  id                            Int                      @id @default(autoincrement())
  nombre                        String
  email                         String                   @unique
  password                      String
  roleId                        Int
  cargoId                       Int?
  activo                        Boolean                  @default(true)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  areasDirector                 Area[]                   @relation("DirectorArea")
  historialCambios              HistorialCambioProceso[]
  incidenciasResponsable        Incidencia[]
  notificaciones                Notificacion[]
  observaciones                 Observacion[]            @relation("AutorObservacion")
  procesosResponsable           Proceso[]                @relation("ResponsableProceso")
  procesosResponsablesMultiples ProcesoResponsable[]     @relation("ProcesoResponsables")
  tareas                        Tarea[]
  cargo                         Cargo?                   @relation(fields: [cargoId], references: [id])
  role                          Role                     @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  procesosParticipantes         Proceso[]                @relation("Participantes")
}

model Cargo {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  usuarios    Usuario[]
}

model Gerencia {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  sigla       String?
  subdivision String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Area {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  directorId  Int?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  director    Usuario?  @relation("DirectorArea", fields: [directorId], references: [id])
  procesos    Proceso[]
}

model Proceso {
  id              Int                      @id @default(autoincrement())
  nombre          String                   @unique
  descripcion     String?
  objetivo        String?
  tipo            String?
  responsableId   Int?
  areaId          Int?
  vicepresidencia String?
  gerencia        String?
  estado          String                   @default("borrador")
  activo          Boolean                  @default(true)
  analisis        String?
  documentoUrl    String?
  documentoNombre String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  sigla           String?
  benchmarking    Benchmarking[]
  contextos       Contexto[]
  documentos      Documento[]
  dofaItems       DofaItem[]
  historial       HistorialCambioProceso[]
  incidencias     Incidencia[]
  normatividades  Normatividad[]
  observaciones   Observacion[]
  area            Area?                    @relation(fields: [areaId], references: [id])
  responsable     Usuario?                 @relation("ResponsableProceso", fields: [responsableId], references: [id])
  responsables    ProcesoResponsable[]
  riesgos         Riesgo[]
  participantes   Usuario[]                @relation("Participantes")
}

model ProcesoResponsable {
  id        Int      @id @default(autoincrement())
  procesoId Int
  usuarioId Int
  modo      String?  @db.VarChar(20) // 'dueño' o 'supervisor' - solo para gerentes
  createdAt DateTime @default(now())
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation("ProcesoResponsables", fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([procesoId, usuarioId])
  @@index([procesoId])
  @@index([usuarioId])
}

model DofaItem {
  id          Int      @id @default(autoincrement())
  procesoId   Int
  tipo        String
  descripcion String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proceso     Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}

model Normatividad {
  id                    Int      @id @default(autoincrement())
  procesoId             Int
  numero                Int
  nombre                String
  estado                String
  regulador             String?
  sanciones             String?
  plazoImplementacion   String?
  cumplimiento          String?
  detalleIncumplimiento String?
  riesgoIdentificado    String?
  clasificacion         String?
  comentarios           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  proceso               Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}

model Contexto {
  id          Int      @id @default(autoincrement())
  procesoId   Int
  tipo        String
  descripcion String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proceso     Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}

model Riesgo {
  id                          Int                   @id @default(autoincrement())
  procesoId                   Int
  numero                      Int
  descripcion                 String
  clasificacion               String?
  zona                        String?
  numeroIdentificacion        String?
  tipologiaNivelI             String?
  tipologiaNivelII            String?
  tipoRiesgoId                Int?
  subtipoRiesgoId             Int?
  objetivoId                  Int?
  causaRiesgo                 String?
  fuenteCausa                 String?
  origen                      String?
  vicepresidenciaGerenciaAlta String?
  siglaVicepresidencia        String?
  gerencia                    String?
  siglaGerencia               String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  subtipoRiesgo               String?
  tipoRiesgo                  String?
  causas                      CausaRiesgo[]
  controles                   Control[]
  evaluacion                  EvaluacionRiesgo?
  eventosMaterializados       EventoMaterializado[]
  incidencias                 Incidencia[]
  planesAccion                PlanAccion[]
  priorizacion                PriorizacionRiesgo?
  objetivo                    Objetivo?             @relation(fields: [objetivoId], references: [id])
  proceso                     Proceso               @relation(fields: [procesoId], references: [id])
  subtipoRiesgoRelacion       SubtipoRiesgo?        @relation(fields: [subtipoRiesgoId], references: [id])
  tipoRiesgoRelacion          TipoRiesgo?           @relation(fields: [tipoRiesgoId], references: [id])

  @@unique([procesoId, numero])
}

model CausaRiesgo {
  id           Int             @id @default(autoincrement())
  riesgoId     Int
  descripcion  String
  fuenteCausa  String?
  frecuencia   String?
  seleccionada Boolean         @default(false)
  orden        Int?
  tipoGestion  String?
  gestion      Json?
  riesgo       Riesgo          @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
  controles    ControlRiesgo[]
}

model ControlRiesgo {
  id                                  Int         @id @default(autoincrement())
  causaRiesgoId                       Int
  descripcion                         String
  tipoControl                         String?
  responsable                         String?
  aplicabilidad                       Int?
  cobertura                           Int?
  facilidadUso                        Int?
  segregacion                         Int?
  naturaleza                          Int?
  desviaciones                        Int?
  puntajeControl                      Int?
  evaluacionPreliminar                String?
  evaluacionDefinitiva                String?
  estandarizacionPorcentajeMitigacion Int?
  disminuyeFrecuenciaImpactoAmbas     String?
  causaRiesgo                         CausaRiesgo @relation(fields: [causaRiesgoId], references: [id], onDelete: Cascade)
}

model EvaluacionRiesgo {
  id                   Int      @id @default(autoincrement())
  riesgoId             Int      @unique
  impactoPersonas      Int
  impactoLegal         Int
  impactoAmbiental     Int
  impactoProcesos      Int
  impactoReputacion    Int
  impactoEconomico     Int
  impactoTecnologico   Int
  probabilidad         Int
  impactoGlobal        Int
  impactoMaximo        Int
  riesgoInherente      Int
  nivelRiesgo          String
  probabilidadResidual Int?
  impactoResidual      Int?
  riesgoResidual       Int?
  nivelRiesgoResidual  String?
  evaluadoPor          String?
  fechaEvaluacion      DateTime @default(now())
  confidencialidadSGSI Int?
  disponibilidadSGSI   Int?
  integridadSGSI       Int?
  riesgo               Riesgo   @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model PriorizacionRiesgo {
  id                  Int          @id @default(autoincrement())
  riesgoId            Int          @unique
  calificacionFinal   Int?
  respuesta           String?
  responsable         String?
  puntajePriorizacion Int?
  fechaAsignacion     DateTime     @default(now())
  planesAccion        PlanAccion[]
  riesgo              Riesgo       @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model PlanAccion {
  id               Int                 @id @default(autoincrement())
  priorizacionId   Int?
  riesgoId         Int?
  incidenciaId     Int?
  nombre           String?
  objetivo         String?
  descripcion      String
  responsable      String?
  fechaInicio      DateTime?
  fechaFin         DateTime?
  fechaProgramada  DateTime?
  fechaEjecucion   DateTime?
  estado           String
  prioridad        Int?
  presupuesto      Float?
  porcentajeAvance Int?
  observaciones    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  incidencia       Incidencia?         @relation(fields: [incidenciaId], references: [id])
  priorizacion     PriorizacionRiesgo? @relation(fields: [priorizacionId], references: [id], onDelete: Cascade)
  riesgo           Riesgo?             @relation(fields: [riesgoId], references: [id])
}

model Control {
  id                    Int      @id @default(autoincrement())
  riesgoId              Int
  descripcion           String?
  tipoControl           String?
  diseño               Int
  ejecucion             Int
  solidez               Int
  efectividad           Float
  riesgoResidual        Float
  clasificacionResidual String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  riesgo                Riesgo   @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model Incidencia {
  id                      Int          @id @default(autoincrement())
  codigo                  String?      @unique
  riesgoId                Int?
  procesoId               Int?
  titulo                  String?
  descripcion             String
  estado                  String
  fechaOcurrencia         DateTime
  fechaReporte            DateTime?
  fechaResolucion         DateTime?
  reportadoPor            String?
  responsableId           Int?
  accionesCorrectivas     String?
  impactosMaterializacion Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  proceso                 Proceso?     @relation(fields: [procesoId], references: [id])
  responsable             Usuario?     @relation(fields: [responsableId], references: [id])
  riesgo                  Riesgo?      @relation(fields: [riesgoId], references: [id])
  planesAccion            PlanAccion[]
}

model TipoRiesgo {
  id          Int             @id @default(autoincrement())
  codigo      String          @unique
  nombre      String          @unique
  descripcion String?
  riesgos     Riesgo[]
  subtipos    SubtipoRiesgo[]
}

model SubtipoRiesgo {
  id           Int        @id @default(autoincrement())
  codigo       String?
  nombre       String
  descripcion  String?
  tipoRiesgoId Int
  riesgos      Riesgo[]
  tipoRiesgo   TipoRiesgo @relation(fields: [tipoRiesgoId], references: [id], onDelete: Cascade)

  @@unique([nombre, tipoRiesgoId], name: "nombre_tipo")
}

model Objetivo {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  descripcion String   @unique
  riesgos     Riesgo[]
}

model FrecuenciaCatalog {
  id          Int    @id @default(autoincrement())
  label       String @unique
  descripcion String
  peso        Int?   @default(3)
}

model FuenteCatalog {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

model OrigenCatalog {
  id     Int     @id @default(autoincrement())
  codigo String? @unique
  nombre String  @unique
}

model ConsecuenciaCatalog {
  id     Int     @id @default(autoincrement())
  codigo String? @unique
  nombre String  @unique
}

model ImpactoTipo {
  id      Int            @id @default(autoincrement())
  clave   String         @unique
  nombre  String         @unique
  niveles ImpactoNivel[]
}

model ImpactoNivel {
  id            Int         @id @default(autoincrement())
  impactoTipoId Int
  nivel         Int
  descripcion   String
  impactoTipo   ImpactoTipo @relation(fields: [impactoTipoId], references: [id], onDelete: Cascade)

  @@unique([impactoTipoId, nivel])
}

model Formula {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  formula     String
  categoria   String?
  activa      Boolean  @default(true)
  variables   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MapaConfig {
  id                          Int                          @id @default(autoincrement())
  nombre                      String
  ejes                        String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  calificacionInherenteConfig CalificacionInherenteConfig?
}

model Configuracion {
  id          Int     @id @default(autoincrement())
  clave       String  @unique
  valor       String
  tipo        String
  descripcion String?
}

model CalificacionInherenteConfig {
  id              Int                           @id @default(autoincrement())
  nombre          String                        @unique @default("Configuración Principal")
  activa          Boolean                       @default(true)
  descripcion     String?
  mapaConfigId    Int?                          @unique
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  mapaConfig      MapaConfig?                   @relation(fields: [mapaConfigId], references: [id])
  excepciones     ExcepcionCalificacion[]
  formulaBase     FormulaCalificacionInherente?
  rangos          RangoCalificacion[]
  reglaAgregacion ReglaAgregacionCalificacion?
}

model FormulaCalificacionInherente {
  id            Int                         @id @default(autoincrement())
  configId      Int                         @unique
  tipoOperacion String                      @default("multiplicacion")
  campos        Json
  orden         Int                         @default(1)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  config        CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model ExcepcionCalificacion {
  id          Int                         @id @default(autoincrement())
  configId    Int
  condiciones Json
  resultado   Float
  prioridad   Int                         @default(1)
  activa      Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  config      CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model RangoCalificacion {
  id            Int                         @id @default(autoincrement())
  configId      Int
  nivelNombre   String
  valorMinimo   Float
  valorMaximo   Float
  incluirMinimo Boolean                     @default(true)
  incluirMaximo Boolean                     @default(true)
  orden         Int
  activo        Boolean                     @default(true)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  config        CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([configId, orden])
}

model ReglaAgregacionCalificacion {
  id             Int                         @id @default(autoincrement())
  configId       Int                         @unique
  tipoAgregacion String                      @default("maximo")
  tablaOrigen    String
  campoOrigen    String
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  config         CalificacionInherenteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  tipo      String
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model Tarea {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  titulo      String
  descripcion String
  estado      String
  prioridad   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}

model Observacion {
  id        Int      @id @default(autoincrement())
  procesoId Int
  autorId   Int
  texto     String
  tipo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  autor     Usuario  @relation("AutorObservacion", fields: [autorId], references: [id])
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}

model HistorialCambioProceso {
  id        Int      @id @default(autoincrement())
  procesoId Int
  usuarioId Int
  tipo      String
  mensaje   String
  fecha     DateTime @default(now())
  cambios   String?
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model EventoMaterializado {
  id               Int      @id @default(autoincrement())
  riesgoId         Int
  descripcion      String
  fecha            DateTime
  impactoEconomico Float?
  planAccion       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  riesgo           Riesgo   @relation(fields: [riesgoId], references: [id], onDelete: Cascade)
}

model Benchmarking {
  id            Int      @id @default(autoincrement())
  procesoId     Int
  entidad       String?
  indicador     String?
  valor         String?
  comparacion   String?
  empresa       String?
  numero        Int?
  riesgo        String?
  clasificacion String?
  calificacion  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  proceso       Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}

model Documento {
  id        Int      @id @default(autoincrement())
  procesoId Int
  nombre    String
  tipo      String
  url       String?
  contenido String?
  tamaño   Int?
  formato   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proceso   Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
}
